@using ResoCafe.ViewModels
@{
    ViewData["Title"] = "Вход / Регистрация";
    ViewData["Page"] = "auth";
    var activeTab = ViewData["Tab"]?.ToString() ?? "login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/sign.css" />
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-tabs">
            <button class="auth-tab @(activeTab == "login" ? "active" : "")"
                    onclick="switchTab('login')" id="tab-login">Вход</button>
            <button class="auth-tab @(activeTab == "register" ? "active" : "")"
                    onclick="switchTab('register')" id="tab-register">Регистрация</button>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        }

        <div class="auth-panel @(activeTab == "login" ? "active" : "")" id="panel-login">
            <form method="post" asp-controller="Account" asp-action="Login">
                @Html.AntiForgeryToken()
                <div class="auth-fields">
                    <input type="text" name="Username" class="auth-input" placeholder="Логин" required />
                    <input type="password" name="Password" class="auth-input" placeholder="Пароль" required />
                </div>
                <button type="submit" class="btn btn-gold auth-submit">Войти</button>
            </form>
        </div>

        <div class="auth-panel @(activeTab == "register" ? "active" : "")" id="panel-register">
            <form method="post" asp-controller="Account" asp-action="Register">
                @Html.AntiForgeryToken()
                <div class="auth-fields">
                    <input type="text" name="Username" class="auth-input" placeholder="Логин" required />
                    <input type="email" name="Email" class="auth-input" placeholder="Почта" />
                    <input type="tel" name="Phone" class="auth-input" placeholder="Номер телефона (необязательно)" />
                    <input type="password" name="Password" class="auth-input" placeholder="Пароль" required />
                    <input type="password" name="PasswordConfirm" class="auth-input" placeholder="Повторите пароль" required />
                </div>
                <button type="submit" class="btn btn-gold auth-submit">Зарегистрироваться</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function switchTab(tab) {
    document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.auth-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
}
</script>
}
